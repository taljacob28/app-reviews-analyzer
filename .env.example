# Copy this file to .env and fill in your values.
# .env is gitignored to keep secrets out of version control.

# Anthropic API key (required only for re-labeling topics with Claude)
ANTHROPIC_API_KEY=

# Scraping settings (optional overrides)
SCRAPE_DELAY_SECONDS=0.5
MAX_REVIEWS_PER_APP=50000

# Microsoft SQL Server (required only for import_to_sqlserver.py)
# Examples:
#   SQL_SERVER_HOST=LAPTOP-ABC\SQLEXPRESS
#   SQL_SERVER_HOST=localhost
SQL_SERVER_HOST=
SQL_SERVER_DATABASE=AppReviewsAnalysis
